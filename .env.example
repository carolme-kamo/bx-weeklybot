# ────────────────────────────────────────────────────────────
# 각자 본인 것으로 입력하는 값
# ────────────────────────────────────────────────────────────

# 내 Slack 유저 ID
# 찾는 법: Slack → 내 프로필 클릭 → ··· 더보기 → 멤버 ID 복사
MY_SLACK_USER_ID=U012ABCDEFG

# 내 Confluence 아이디 (카카오 이메일 @ 앞부분)
# 예) carol.me@kakaomobility.com → carol.me
MY_CONFLUENCE_USERNAME=hong.gildong

# 내 Confluence PAT (개인 액세스 토큰)
# 발급: wiki.daumkakao.com → 프로필 → 개인 설정 → 보안 → Personal Access Tokens
CONFLUENCE_API_TOKEN=your-own-confluence-pat-here

# ────────────────────────────────────────────────────────────
# 팀 공통 값 (carol.me에게 받기)
# ────────────────────────────────────────────────────────────

# Slack 봇 토큰 (팀 전체 공유, 개인 것 아님)
SLACK_BOT_TOKEN=xoxb-받은값-입력

# ────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
